generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  username  String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Rider {
  id                Int       @id @default(autoincrement())
  name              String
  phone             String    @unique
  email             String?   @unique
  password          String
  status            Int       @default(0) // 0: Active, 1: Suspended, 2: Offline
  nid               String?
  assignedVehicleId Int? // Admin can permanently assign a vehicle
  assignedVehicle   Vehicle?  @relation("AssignedVehicle", fields: [assignedVehicleId], references: [id])
  trips             Trip[]
  orders            Order[]
  lastLat           Float? // Last known GPS latitude
  lastLng           Float? // Last known GPS longitude
  lastArea          String? // Last known neighborhood/locality
  lastUpdated       DateTime? // Timestamp of last signal
  createdAt         DateTime  @default(now())
  rating            Float?    @default(0)
  resetOtpHash      String?
  resetOtpExpiry    DateTime?
  updatedAt         DateTime  @updatedAt
}

model Vehicle {
  id             Int      @id @default(autoincrement())
  regNumber      String   @unique
  model          String
  type           String   @default("electric")
  status         Int      @default(0) // 0: Available, 1: In Use, 2: Maintenance
  battery        Int      @default(100)
  image          String?
  trips          Trip[]
  assignedRiders Rider[]  @relation("AssignedVehicle") // riders assigned to this vehicle
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Trip {
  id           Int           @id @default(autoincrement())
  riderId      Int
  vehicleId    Int
  startTime    DateTime      @default(now())
  endTime      DateTime?
  status       Int           @default(0) // 0: Ongoing, 1: Completed, 2: Cancelled
  distance     Float?        @default(0)
  fare         Float?        @default(0)
  startLoc     String?
  endLoc       String?
  rider        Rider         @relation(fields: [riderId], references: [id])
  vehicle      Vehicle       @relation(fields: [vehicleId], references: [id])
  locationLogs LocationLog[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Customer {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String   @unique
  phone     String   @unique
  password  String?
  street    String?
  city      String?
  state     String?
  zip       String?
  homeAddress String?
  workAddress String?
  image     String?
  resetOtpHash String?
  resetOtpExpiry DateTime?
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LocationLog {
  id        Int      @id @default(autoincrement())
  tripId    Int
  lat       Float
  lng       Float
  timestamp DateTime @default(now())
  trip      Trip     @relation(fields: [tripId], references: [id])
  createdAt DateTime @default(now())
}

model Order {
  id         Int      @id @default(autoincrement())
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])
  riderId    Int?
  rider      Rider?   @relation(fields: [riderId], references: [id])
  status     Int      @default(0) // 0: Pending, 1: Accepted, 2: Arrived, 3: Started, 4: Delivered, 5: Canceled
  date       DateTime @default(now())

  // New ride request fields:
  pickupLat   Float?
  pickupLng   Float?
  dropLat     Float?
  dropLng     Float?
  pickupLoc   String?
  dropLoc     String?
  otp         String?
  paymentMode String? @default("Cash")
  amount      Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
