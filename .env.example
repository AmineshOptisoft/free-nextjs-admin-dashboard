# Copy to .env.local and fill in (XAMPP default: user root, empty password)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=tepay
MYSQL_CONNECTION_LIMIT=10

# Random long string (login cookie signing)
SESSION_SECRET=

# Admin passwords in DB must be bcrypt hashes (e.g. PHP password_hash or bcrypt CLI).

# Minutes after admin assigns a payout before the assigned agent may approve (PENDING → APPROVED_BY_AGENT). Use 0 for no wait.
PAYOUT_AGENT_APPROVE_DELAY_MINUTES=10
